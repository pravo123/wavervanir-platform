# Copy to api/.env for local dev. Never commit a real .env.

WAVERVANIR_ENV=dev
WAVERVANIR_DB_URL=sqlite:///./wavervanir_api.sqlite
WAVERVANIR_API_KEY_PEPPER=local-dev-pepper-change-me
WAVERVANIR_RATE_LIMIT_FREE=100
WAVERVANIR_RATE_LIMIT_PAID=5000

# Stripe (TEST MODE ONLY in MVP). Get from https://dashboard.stripe.com/test/webhooks
STRIPE_API_KEY=sk_test_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE

# Optional — Stripe Price ids for self-serve plans. Leave blank to inherit
# plan defaults from plans.py.
STRIPE_PRICE_RESEARCHER=price_test_REPLACE
STRIPE_PRICE_PRO=price_test_REPLACE

# ── Data providers (all OPTIONAL — leave blank to self-disable) ──
# Financial Modeling Prep (market quotes). https://financialmodelingprep.com
FMP_API_KEY=
# Bullflow-style options flow. Set either the API key OR a local file path.
BULLFLOW_API_KEY=
BULLFLOW_DATA_FILE=
