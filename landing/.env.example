# Copy to landing/.env for local dev. Never commit a real .env.
#
# These VITE_* values are PUBLIC (Vite inlines them into the built bundle).
# Only place values that are safe to publish — i.e. Stripe Payment Link URLs.
# NEVER put sk_*, whsec_*, or any server-side secret here.

# Test-mode Stripe Payment Links (replace with your actual links from the
# Stripe dashboard in test mode):
VITE_STRIPE_LINK_RESEARCHER=https://buy.stripe.com/test_REPLACE_RESEARCHER
VITE_STRIPE_LINK_PRO=https://buy.stripe.com/test_REPLACE_PRO

# Where the institutional/regulator CTAs route (anchor on the same page).
VITE_INSTITUTIONAL_HREF=#waitlist

# Public origin of the wavervanir-api service.
# When set, the landing dashboard's provider-status tiles call
# GET ${VITE_WAVERVANIR_API_URL}/v1/data/providers on mount.
# When blank or unreachable, the tiles render the built-in demo fixtures
# silently (no error UI is shown unless the fetch fails after starting).
#
# Examples:
#   VITE_WAVERVANIR_API_URL=http://127.0.0.1:8000        # local dev
#   VITE_WAVERVANIR_API_URL=https://api.wavervanir.com   # production
#
# This MUST point at a PUBLIC origin. VITE_* values are baked into the
# browser bundle — never put server-side secrets, API keys, bearer tokens,
# or anything beginning with sk_/whsec_/cus_/Bearer in any VITE_* var.
# No Authorization header is sent in this slice; protected APIs must add
# a public reverse proxy or a future token flow.
VITE_WAVERVANIR_API_URL=
