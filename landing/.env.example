# Copy to landing/.env for local dev. Never commit a real .env.
#
# These VITE_* values are PUBLIC (Vite inlines them into the built bundle).
# Only place values that are safe to publish — i.e. Stripe Payment Link URLs.
# NEVER put sk_*, whsec_*, or any server-side secret here.

# Test-mode Stripe Payment Links (replace with your actual links from the
# Stripe dashboard in test mode):
VITE_STRIPE_LINK_RESEARCHER=https://buy.stripe.com/test_REPLACE_RESEARCHER
VITE_STRIPE_LINK_PRO=https://buy.stripe.com/test_REPLACE_PRO

# Where the institutional/regulator CTAs route (anchor on the same page).
VITE_INSTITUTIONAL_HREF=#waitlist
